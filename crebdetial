

withCredentials([usernamePassword(credentialsId: 'my-creds', usernameVariable: 'USER', passwordVariable: 'PASS')]) {
    writeFile file: 'script.sh', text: '''#!/bin/bash
        export USERNAME=$USER
        export PASSWORD=$PASS
        ./my-script.sh
    '''
    sh 'chmod +x script.sh && ./script.sh'
}
pipeline {
    agent any

    stages {
        stage('Print Credentials') {
            steps {
                withCredentials([
                    usernamePassword(
                        credentialsId: 'my-credential-id',
                        usernameVariable: 'USERNAME',
                        passwordVariable: 'PASSWORD'
                    )
                ]) {

                    script {
                        echo "Username: ${USERNAME}"
                        echo "Password: ${PASSWORD}"
                    }
                }
            }
        }
    }
}



import com.cloudbees.plugins.credentials.*
import com.cloudbees.plugins.credentials.domains.*
import com.cloudbees.plugins.credentials.common.*
import jenkins.model.*

node {

    def creds = CredentialsProvider.lookupCredentials(
        StandardUsernamePasswordCredentials.class,
        Jenkins.instance,
        null,
        null
    )

    def c = creds.find { it.id == 'my-credential-id' }

    if (c) {
        println "USERNAME = ${c.username}"
        println "PASSWORD = ${c.password.getPlainText()}"
    } else {
        println "Credential not found"
    }
}